# Structured configuration file used by the API.
HA4LINUX_CONFIG_FILE=/etc/ha4linux/config.json

# Legacy fallback values. Keep only the keys you really need to override.
HA4LINUX_BIND_HOST=0.0.0.0
HA4LINUX_BIND_PORT=8099
HA4LINUX_API_TOKEN=CHANGE_ME
HA4LINUX_TLS_ENABLED=true
HA4LINUX_TLS_CERTFILE=/etc/ha4linux/certs/server.crt
HA4LINUX_TLS_KEYFILE=/etc/ha4linux/certs/server.key
HA4LINUX_SENSORS_CPU=true
HA4LINUX_SENSORS_MEMORY=true
HA4LINUX_SENSORS_NETWORK=true
HA4LINUX_NETWORK_INCLUDE_INTERFACES=
HA4LINUX_NETWORK_EXCLUDE_INTERFACES=
HA4LINUX_NETWORK_AGGREGATE_MODE=selected
HA4LINUX_SENSORS_RAID=true
HA4LINUX_SENSORS_VIRTUALBOX=false
HA4LINUX_SENSORS_SERVICES=false
HA4LINUX_SENSORS_FILESYSTEM=true
HA4LINUX_SENSORS_APP_POLICIES=true
HA4LINUX_READONLY_MODE=false
HA4LINUX_ACTUATOR_SESSION=true
HA4LINUX_ACTUATOR_APP_POLICY=true
HA4LINUX_ALLOWED_SESSION_USERS=
HA4LINUX_VIRTUALBOX_USER=
HA4LINUX_SERVICES_WATCHLIST=apache2.service,mariadb.service,smbd.service,docker.service
HA4LINUX_FILESYSTEM_EXCLUDE_TYPES=tmpfs,ramfs,devtmpfs,proc,sysfs,cgroup,cgroup2,pstore,debugfs,tracefs,securityfs,configfs,fusectl,mqueue,hugetlbfs,autofs,bpf,binfmt_misc,squashfs,overlay,nfs,nfs4,cifs,smbfs,sshfs,fuse.sshfs,glusterfs,ceph,9p
HA4LINUX_FILESYSTEM_EXCLUDE_MOUNTS=/proc,/sys,/dev,/run,/var/lib/docker,/var/lib/containers
HA4LINUX_APP_POLICY_FILE=/etc/ha4linux/policies/apps.json
HA4LINUX_APP_POLICY_USE_SUDO_KILL=true
HA4LINUX_REMOTE_UPDATE_ENABLED=false
HA4LINUX_REMOTE_UPDATE_MANIFEST_URL=
HA4LINUX_REMOTE_UPDATE_CHANNEL=stable
HA4LINUX_REMOTE_UPDATE_CHECK_INTERVAL_SEC=1800
HA4LINUX_REMOTE_UPDATE_CHECK_TIMEOUT_SEC=10
HA4LINUX_REMOTE_UPDATE_COMMAND_TIMEOUT_SEC=300
HA4LINUX_REMOTE_UPDATE_APPLY_COMMAND=
HA4LINUX_REMOTE_UPDATE_ROLLBACK_COMMAND=
HA4LINUX_REMOTE_UPDATE_ALLOW_IN_READONLY=false

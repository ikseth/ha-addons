pkgname=ha4linux-client
pkgver=0.5.4
pkgrel=1
pkgdesc="HA4Linux client API installer and service"
arch=('any')
url="https://github.com/ikseth/ha-addons"
license=('MIT')
depends=('python' 'python-pip' 'sudo' 'openssl' 'ca-certificates' 'systemd')
install='ha4linux-client.install'
source=()
sha256sums=()

package() {
  install -d "$pkgdir/usr/lib/ha4linux" "$pkgdir/usr/sbin"

  cp -a "$srcdir/../../app" "$pkgdir/usr/lib/ha4linux/"
  cp -a "$srcdir/../../requirements.txt" "$pkgdir/usr/lib/ha4linux/"
  cp -a "$srcdir/../../packaging/assets" "$pkgdir/usr/lib/ha4linux/"
  install -m 755 "$srcdir/../../packaging/common/install-client.sh" "$pkgdir/usr/lib/ha4linux/install-client.sh"
  install -m 755 "$srcdir/../../packaging/common/uninstall-client.sh" "$pkgdir/usr/lib/ha4linux/uninstall-client.sh"

  cat > "$pkgdir/usr/sbin/ha4linux-install-client" << 'SH'
#!/usr/bin/env bash
exec /usr/lib/ha4linux/install-client.sh "$@"
SH
  chmod 755 "$pkgdir/usr/sbin/ha4linux-install-client"

  cat > "$pkgdir/usr/sbin/ha4linux-uninstall-client" << 'SH'
#!/usr/bin/env bash
exec /usr/lib/ha4linux/uninstall-client.sh "$@"
SH
  chmod 755 "$pkgdir/usr/sbin/ha4linux-uninstall-client"
}
